{
  "name": "@rfkit/json-rpc-websocket",
  "version": "0.2.5",
  "type": "module",
  "description": "A lightweight JSON-RPC 2.0 client implementation over WebSocket, supporting request-response, notifications, and batch processing",
  "author": "Hxgh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hxgh/json-rpc-websocket"
  },
  "homepage": "https://github.com/Hxgh/json-rpc-websocket#readme",
  "bugs": {
    "url": "https://github.com/Hxgh/json-rpc-websocket/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "json-rpc",
    "websocket",
    "rpc",
    "client",
    "remote-procedure-call",
    "typescript",
    "real-time",
    "communication",
    "async"
  ],
  "scripts": {
    "changeset": "changeset",
    "build": "rslib build && node ./scripts/release/write-dist-package.mjs",
    "build:release": "pnpm build",
    "build:analyze": "rslib build --analyze",
    "check": "biome check --write",
    "dev": "rslib build --watch",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && pnpm test:runtime",
    "test:runtime": "node test-inbound-mode.mjs",
    "build:npm": "pnpm release:publish",
    "publish:npm": "pnpm build && npm publish ./dist --access public",
    "release:publish": "node ./scripts/release/publish-release.mjs",
    "release:version": "changeset version",
    "validate:release": "pnpm typecheck && pnpm build:release && pnpm test:runtime && npm pack ./dist --dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@biomejs/biome": "^1.9.4",
    "@rslib/core": "^0.5.3",
    "@types/node": "^22.8.1",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "ws": "^8.20.1"
  },
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.30.3"
}
