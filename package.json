{
  "name": "@rfkit/json-rpc-websocket",
  "version": "0.2.5",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hxgh/json-rpc-websocket"
  },
  "homepage": "https://github.com/Hxgh/json-rpc-websocket#readme",
  "bugs": {
    "url": "https://github.com/Hxgh/json-rpc-websocket/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "changeset": "changeset",
    "build": "rslib build",
    "build:analyze": "rslib build --analyze",
    "check": "biome check --write",
    "dev": "rslib build --watch",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && node test-inbound-mode.mjs",
    "build:npm": "rslib build && nrm use npm && cd dist && npm publish --access public && cd ../",
    "publish:npm": "pnpm build && npm publish ./dist --access public",
    "release:publish": "pnpm publish:npm",
    "release:version": "changeset version && node ./scripts/sync-public-package-version.mjs",
    "validate:release": "pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@biomejs/biome": "^1.9.4",
    "@rslib/core": "^0.5.3",
    "@types/node": "^22.8.1",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "ws": "^8.20.1"
  }
}
